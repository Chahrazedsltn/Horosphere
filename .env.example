# ─────────────────────────────────────────────────────────────────────────────
#  HOROSPHERE — Variables d'environnement
#  1. Copier ce fichier : cp .env.example .env
#  2. Renseigner toutes les valeurs ci-dessous
#  3. Générer les clés JWT : ./scripts/setup-jwt.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
# Générer avec : openssl rand -hex 32
APP_SECRET=change_me_to_a_random_64_char_hex_string

# ── Base de données ───────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root_password
DB_NAME=horosphere
DB_USER=horosphere
DB_PASSWORD=change_me_db_password

# ── JWT Authentication ────────────────────────────────────────────────────────
# Générer les clés avec : ./scripts/setup-jwt.sh
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Choisir une passphrase forte et unique
JWT_PASSPHRASE=change_me_jwt_passphrase_min_32_chars

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
# URL publique du frontend (utilisée pour les emails de reset password)
APP_FRONTEND_URL=http://localhost

# ── Google Maps (géofencing) ──────────────────────────────────────────────────
# Obtenir une clé sur https://console.cloud.google.com/
# APIs requises : Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Mailer ────────────────────────────────────────────────────────────────────
# Dev  : smtp://mailpit:1025
# Prod : smtp://user:pass@smtp.provider.com:587?encryption=tls
MAILER_DSN=smtp://mailpit:1025

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev  : ^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
# Prod : ^https://votre-domaine\.com$
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# ── Messenger / Queue ─────────────────────────────────────────────────────────
# Dev  : doctrine://default?queue_name=async  (utilise MariaDB)
# Prod : doctrine://default?queue_name=async  (ou Redis : redis://localhost:6379/messages)
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async

# ── Gotenberg (PDF) ───────────────────────────────────────────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ── Backup base de données ────────────────────────────────────────────────────
# Nombre de sauvegardes à conserver
BACKUP_MAX_KEEP=7
# Cron : tous les jours à 2h du matin
BACKUP_CRON=0 2 * * *

# ── Production uniquement ─────────────────────────────────────────────────────
# Domaine de production (pour Traefik + Let's Encrypt)
DOMAIN=votre-domaine.com
# Email pour les notifications Let's Encrypt
ACME_EMAIL=admin@votre-domaine.com

# ── Observabilité (optionnel) ─────────────────────────────────────────────────
# Installer sentry/sentry-symfony puis décommenter dans monolog.yaml
# SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_DSN=
